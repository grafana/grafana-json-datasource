{
  "name": "grafana-json-datasource",
  "version": "1.4.0",
  "description": "A data source plugin for loading JSON APIs into Grafana",
  "keywords": [
    "grafana",
    "json"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "yarn playwright test",
    "lint": "eslint --cache .",
    "lint:fix": "yarn run lint --fix",
    "server": "docker compose up --build",
    "sign": "sign-plugin",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test:e2e": "grafana-e2e run",
    "typecheck": "tsc --noEmit"
  },
  "homepage": "https://grafana.com/plugins/marcusolsson-json-datasource",
  "bugs": "https://github.com/grafana/grafana-json-datasource/issues",
  "repository": "github:grafana/grafana-json-datasource",
  "author": {
    "name": "Grafana Labs",
    "url": "https://grafana.com"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "12.4.5",
    "@grafana/plugin-ui": "0.17.1",
    "@grafana/runtime": "12.4.5",
    "@grafana/schema": "12.4.5",
    "@grafana/ui": "12.4.5",
    "dayjs": "1.11.21",
    "jsonata": "2.2.2",
    "jsonpath-plus": "10.4.0",
    "memory-cache": "0.2.0",
    "moment": "2.30.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@grafana/e2e-selectors": "13.1.0",
    "@grafana/eslint-config": "9.0.0",
    "@grafana/plugin-e2e": "3.10.0",
    "@grafana/sign-plugin": "3.3.3",
    "@grafana/tsconfig": "2.2.0",
    "@openfeature/core": "1.11.0",
    "@openfeature/web-sdk": "1.9.0",
    "@playwright/test": "1.61.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.46",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "0.2.39",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@types/jest": "30.0.0",
    "@types/memory-cache": "0.2.6",
    "@types/node": "25.9.5",
    "@types/react": "18.3.31",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "copy-webpack-plugin": "14.0.0",
    "cspell": "10.0.1",
    "css-loader": "7.1.4",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-webpack-plugin": "5.0.3",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "30.4.2",
